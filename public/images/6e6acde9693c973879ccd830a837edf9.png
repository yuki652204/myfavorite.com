und-position-x:0}to{background-position-x:-200%}}@keyframes bgslide{from{background-position-x:0}to{background-position-x:-200%}}.wpp-widget-block-placeholder,.wpp-shortcode-placeholder{margin:0 auto;width:60px;height:3px;background:#dd3737;background:linear-gradient(90deg,#dd3737 0%,#571313 10%,#dd3737 100%);background-size:200% auto;border-radius:3px;-webkit-animation:bgslide 1s infinite linear;animation:bgslide 1s infinite linear}</style><link rel="icon" href="https://hikarinotama.com/wp-content/uploads/2025/05/cropped-illustrain09-pengin5-1-32x32.png" sizes="32x32"/><link rel="icon" href="https://hikarinotama.com/wp-content/uploads/2025/05/cropped-illustrain09-pengin5-1-192x192.png" sizes="192x192"/><link rel="apple-touch-icon" href="https://hikarinotama.com/wp-content/uploads/2025/05/cropped-illustrain09-pengin5-1-180x180.png"/><meta name="msapplication-TileImage" content="https://hikarinotama.com/wp-content/uploads/2025/05/cropped-illustrain09-pengin5-1-270x270.png"/><style id="wp-custom-css">/* フォーム全体のスタイル */
.wpcf7-form {
  max-width: 800px;
  margin: 0 auto;
}

/* 各フィールドラッパー */
.wpcf7-form .form-field {
  margin-bottom: 20px;
}

/* ラベル */
.wpcf7-form .form-field__head label {
  font-weight: bold;
  display: block;
}

/* 必須タグ */
.wpcf7-form .form-field__tag {
  background: #e53935;
  color: white;
  padding: 2px 6px;
  font-size: 12px;
  border-radius: 3px;
  margin-left: 5px;
}

/* テキスト入力フィールド */
.wpcf7-form .wpcf7-text,
.wpcf7-form .wpcf7-textarea,
.wpcf7-form .wpcf7-select {
  width: 100%;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 4px;
}

/* 送信ボタン */
.wpcf7-form .wpcf7-submit {
  background: #4CAF50;
  color: white;
  padding: 12px 24px;
  border: none;
  border-radius: 4px;
  font-size: 16px;
  cursor: pointer;
}</style></head><body><header id="header"><div class="inner"><h1 class="header-logo"><a href="/">四つ葉のクローバー</a></h1><div class="header-sub"></div><div class="drawer"><div class="drawer-icon"> <span class="drawer-open"><i class="fas fa-bars"></i></span> <span class="drawer-close"><i class="fas fa-times"></i></span></div><div class="drawer-content"><nav class="drawer-nav"><div class="drawer-list"><ul><li class="page_item page-item-89"><a href="https://hikarinotama.com/brog-2/">BROG</a></li><li class="page_item page-item-87"><a href="https://hikarinotama.com/contact/">CONTACT</a></li><li class="page_item page-item-83"><a href="https://hikarinotama.com/home/">HOME</a></li><li class="page_item page-item-12"><a href="https://hikarinotama.com/privacy-policy-2/">Privacy Policy</a></li><li class="page_item page-item-2"><a href="https://hikarinotama.com/sample-page/">Sample Page</a></li><li class="page_item page-item-268"><a href="https://hikarinotama.com/">トップページ</a></li><li class="page_item page-item-278"><a href="https://hikarinotama.com/about/">当店について</a></li><li class="page_item page-item-281 current_page_parent"><a href="https://hikarinotama.com/articles/">記事一覧デス</a></li><li class="page_item page-item-283 page_item_has_children"><a href="https://hikarinotama.com/contact-2/">お問い合わせ</a></li><li class="page_item page-item-287"><a href="https://hikarinotama.com/privacy/">プライバシーポリシー</a></li></ul></div></nav></div></div></div></header><nav class="header-nav"><div class="inner"><ul id="menu-%e3%82%b0%e3%83%ad%e3%83%bc%e3%83%90%e3%83%ab%e3%83%a1%e3%83%8b%e3%83%a5%e3%83%bc" class="header-list"><li id="menu-item-340" class="menu-item menu-item-type-post_type menu-item-object-page menu-item-home menu-item-340"><a href="https://hikarinotama.com/">トップページ</a></li><li id="menu-item-341" class="menu-item menu-item-type-post_type menu-item-object-page menu-item-341"><a href="https://hikarinotama.com/about/">当店について</a></li><li id="menu-item-342" class="menu-item menu-item-type-post_type m